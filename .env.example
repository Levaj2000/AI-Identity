# AI Identity — Environment Variables
# Quick start:  make setup   (generates .env with real keys from this template)
# Manual:       cp .env.example .env  then fill in values below

# ── Database ─────────────────────────────────────────────────────────────
# Docker Compose overrides this automatically — no need to change for local dev.
# For Neon (production): postgresql://user:password@host.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_identity

# ── Security (required — generate once with `make setup`) ───────────────
# Fernet key for encrypting upstream credentials
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# HMAC-SHA256 key for API ↔ Gateway internal auth (must match on both services)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
INTERNAL_SERVICE_KEY=

# HMAC key for audit log integrity chain
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AUDIT_HMAC_KEY=dev-hmac-key-change-in-production

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ───────────────────────────────────────────────────────────
API_PORT=8001

# ── Gateway ──────────────────────────────────────────────────────────────
GATEWAY_PORT=8002

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── API Key Settings ────────────────────────────────────────────────────
API_KEY_PREFIX=aid_sk_
ADMIN_KEY_PREFIX=aid_admin_
KEY_ROTATION_GRACE_HOURS=24

# ── Clerk Authentication ──────────────────────────────────────────────
# Clerk instance URL for JWT verification (e.g. https://your-app.clerk.accounts.dev)
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_ISSUER=

# ── Stripe Billing ────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products/prices in Stripe Dashboard, paste the price_xxx IDs here
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_SUCCESS_URL=https://dashboard.ai-identity.co/settings?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://dashboard.ai-identity.co/settings

# ── Perplexity AI — "What happened here?" audit summaries ──────────────
# Get an API key at https://docs.perplexity.ai
# Leave empty to disable the AI summary feature
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# ── Sentry Error Monitoring ────────────────────────────────────────────
# Create a Sentry project at https://sentry.io → Settings → Projects → Create
# Use separate DSNs for API/Gateway vs. Dashboard (different Sentry projects)
# Leave empty to disable Sentry (safe for local dev)
SENTRY_DSN=

# ── App Metadata ────────────────────────────────────────────────────────
APP_VERSION=0.1.0
