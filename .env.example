# AI Identity — Environment Variables
# Copy this file to .env and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/ai_identity

# Environment
ENVIRONMENT=development
DEBUG=false

# API Server
API_PORT=8001

# Gateway
GATEWAY_PORT=8002

# API Key Settings
API_KEY_PREFIX=aid_sk_
ADMIN_KEY_PREFIX=aid_admin_
KEY_ROTATION_GRACE_HOURS=24
