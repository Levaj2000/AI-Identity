# AI Identity — Infra Cost Report credentials
# Copy to `.env` (gitignored), fill in, then:  set -a; . ./.env; set +a
# Every block is optional — a missing one just downgrades that section to
# "not configured" so you can test incrementally.

# --- Neon (Postgres) ---------------------------------------------------------
# Console → Organization Settings → API Keys → "Create new API key" (org-scoped)
NEON_API_KEY=
NEON_ORG_ID=org-divine-dawn-95876960

# --- MongoDB Atlas -----------------------------------------------------------
# Org → Access Manager → API Keys → Create. Role: "Organization Read Only".
# Add this machine's egress IP to the key's Access List (Atlas requires it).
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_ORG_ID=69fdf3233ad9d2d401b85aa9
# Atlas hides credit balance from the API. Optionally paste it from
# Billing → Overview → Credits to auto-compute runway (update ~quarterly):
ATLAS_CREDIT_BALANCE_USD=
ATLAS_CREDIT_EXPIRY=

# --- GCP / GKE ---------------------------------------------------------------
GCP_PROJECT=project-8bbb04f8-fda8-462e-bc2
GCP_BILLING_ACCOUNT=0195CB-21BCB8-48243F
# For EXACT $: enable Billing → BigQuery export, then set the table here:
#   format: project.dataset.gcp_billing_export_v1_XXXXXX
GCP_BILLING_BQ_TABLE=
# GCP credit balances (console-only — paste from Billing → Credits, refresh ~monthly):
GCP_INFRA_CREDIT_USD=
GCP_INFRA_CREDIT_EXPIRY=
GCP_VERTEX_CREDIT_USD=
GCP_VERTEX_CREDIT_EXPIRY=

# --- Sentry (error monitoring) -----------------------------------------------
SENTRY_ORG=ai-identity
SENTRY_REGION_URL=https://us.sentry.io
# Plan is manual ('team'|'developer'|'business') — the API doesn't expose it reliably.
SENTRY_PLAN=
# Optional: Settings → Auth Tokens → create (org:read, project:read) to auto-pull
# error volume. Without it, the manual SENTRY_ERRORS_30D / SENTRY_PROJECTS below are used.
SENTRY_AUTH_TOKEN=
SENTRY_ERRORS_30D=
SENTRY_PROJECTS=
# Set true to mark a paid plan as a deliberate choice (suppresses the
# downgrade nag — e.g. Team retained for tracing/spans headroom).
SENTRY_PLAN_INTENTIONAL=

# --- Email delivery (SMTP) ---------------------------------------------------
# Gmail app password (Google Account → Security → App passwords). 16 chars.
REPORT_TO=levaj2000@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
