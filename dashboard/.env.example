# AI Identity Dashboard — Environment Variables
# Copy to .env for local development (Vite loads .env automatically)

# API base URL (no trailing slash)
# Local dev:  http://localhost:8001  (default — Vite also proxies /api to this)
# Production: https://ai-identity-api.onrender.com
VITE_API_BASE_URL=http://localhost:8001

# Clerk authentication
# Get your publishable key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# Sentry error monitoring (leave empty to disable)
# Create a Browser JavaScript project at https://sentry.io
VITE_SENTRY_DSN=
