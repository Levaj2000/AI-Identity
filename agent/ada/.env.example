# Ada agent — environment configuration
#
# Copy to `.env` and fill in real values. Never commit `.env`.

# ── Vertex AI (preferred — uses Google for Startups credits) ─────────────
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── OR Google AI Studio (simpler for local testing, separate quota) ──────
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your_ai_studio_key

# ── AI Identity dogfood ──────────────────────────────────────────────────
# Register Ada in the AI Identity dashboard, then paste her developer key
# here. This is what makes the `query_ai_identity_agent` tool work.
AI_IDENTITY_API_KEY=
AI_IDENTITY_API_URL=https://api.ai-identity.co

# ── Workspace ────────────────────────────────────────────────────────────
# Where Ada's code-reading tools should look. Defaults to the repo root.
# Override when deploying Ada to a workspace other than the AI Identity repo.
# ADA_WORKSPACE_ROOT=/path/to/workspace
