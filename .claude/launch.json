{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "dashboard"
    },
    {
      "name": "landing-page",
      "runtimeExecutable": "./node_modules/.bin/next",
      "runtimeArgs": ["dev", "-p", "3000"],
      "port": 3000,
      "cwd": "landing-page"
    },
    {
      "name": "assets",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "assets", "-l", "3001"],
      "port": 3001
    }
  ]
}
