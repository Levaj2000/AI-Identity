# Version control
.git
.gitignore

# Python
__pycache__
*.py[cod]
*.egg-info
.venv
venv
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# Environment
.env
.env.*

# Dashboard (not needed for Python services)
dashboard/node_modules
dashboard/dist

# IDE
.vscode
.idea
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Not needed in container images
k8s/
landing-page/
sdk/
# Exclude cli/ EXCEPT the verifier the Case File bundle ships to customers.
# (Without the exception this was excluded from the image, so every bundle
# shipped without ai_identity_verify.py and was unverifiable.)
cli/*
!cli/ai_identity_verify.py
docs/
.github/
.claude/
*.md

# Ada-specific exclusions. Docker reads .dockerignore from the build
# CONTEXT root, not from the Dockerfile's directory — so an
# agent/.dockerignore is silently ignored by `docker build -f
# agent/Dockerfile .` (the cloudbuild + GH Actions invocation pattern).
# Keep these patterns here so tests/evals/launcher artifacts don't leak
# into the Ada image and ADK's AgentLoader doesn't try to scan them.
agent/tests/
agent/evals/
agent/dist/
agent/.venv/
agent/launcher/build_icon.py
agent/*.icns
agent/ada/.env
agent/ada/.env.*
